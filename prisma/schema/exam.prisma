model Exam {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId         String   @map("group_id") @db.Uuid
  title           String   @db.VarChar(200)
  institution     String   @db.VarChar(120)
  organization    String   @db.VarChar(120)
  year            Int
  roleName        String   @map("role_name") @db.VarChar(120)
  durationMinutes Int      @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sections  ExamSection[]
  questions ExamQuestion[]
  attempts  ExamAttempt[]

  @@index([groupId])
  @@index([year])
  @@map("exams")
}

model ExamSection {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId String @map("exam_id") @db.Uuid
  name   String @db.VarChar(120)
  weight Float  @default(1)
  sortOrder Int @default(0) @map("sort_order")

  exam      Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions ExamQuestion[]

  @@index([examId])
  @@map("exam_sections")
}

model ExamQuestion {
  examId     String  @map("exam_id") @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  sectionId  String? @map("section_id") @db.Uuid
  sortOrder  Int     @default(0) @map("sort_order")

  exam     Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  section  ExamSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@id([examId, questionId])
  @@map("exam_questions")
}

model ExamAttempt {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  examId           String    @map("exam_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  startedAt        DateTime  @default(now()) @map("started_at")
  finishedAt       DateTime? @map("finished_at")
  score            Float     @default(0)
  totalCorrect     Int       @default(0) @map("total_correct")
  totalWrong       Int       @default(0) @map("total_wrong")
  totalTimeSeconds Int       @default(0) @map("total_time_seconds")

  exam    Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers ExamAttemptAnswer[]

  @@index([examId, userId])
  @@map("exam_attempts")
}

model ExamAttemptAnswer {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attemptId             String   @map("attempt_id") @db.Uuid
  questionId            String   @map("question_id") @db.Uuid
  selectedAlternativeId String   @map("selected_alternative_id") @db.Uuid
  timeSpentSeconds      Int      @map("time_spent_seconds")
  isCorrect             Boolean  @map("is_correct")
  answeredAt            DateTime @default(now()) @map("answered_at")

  attempt             ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question            Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedAlternative Alternative @relation("ExamAttemptAnswers", fields: [selectedAlternativeId], references: [id], onDelete: Restrict)

  @@unique([attemptId, questionId])
  @@map("exam_attempt_answers")
}
